{
  "manifest_version": 3,
  "name": "Clalit Appointment Finder",
  "version": "1.0.0",
  "description": "מוצא תורים מוקדמים יותר לאורתופד בכללית ומתריע כשמתפנה תור",

  "permissions": [
    "activeTab",
    "storage",
    "alarms",
    "notifications",
    "tabs"
  ],

  "host_permissions": [
    "https://e-services.clalit.co.il/*"
  ],

  "content_scripts": [
    {
      "matches": [
        "https://e-services.clalit.co.il/*"
      ],
      "js": [
        "content-scripts/injector.js"
      ],
      "css": [
        "content-scripts/styles.css"
      ],
      "run_at": "document_start",
      "all_frames": true
    }
  ],

  "web_accessible_resources": [
    {
      "resources": [
        "content-scripts/panel.html",
        "content-scripts/panel.js",
        "content-scripts/page-interceptor.js",
        "assets/*"
      ],
      "matches": [
        "https://e-services.clalit.co.il/*"
      ]
    }
  ],

  "background": {
    "service_worker": "background/service-worker.js"
  },

  "action": {
    "default_title": "Clalit Appointment Finder - לחץ לפתיחת הפאנל",
    "default_icon": {
      "16": "assets/icon16.png",
      "32": "assets/icon32.png",
      "48": "assets/icon48.png",
      "128": "assets/icon128.png"
    }
  },

  "icons": {
    "16": "assets/icon16.png",
    "32": "assets/icon32.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  }
}
